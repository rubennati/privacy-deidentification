# Environment / secrets
.env
.env.local
*.local
*.sqlite3
*.sqlite3-shm
*.sqlite3-wal

# Runtime data (bind-mounted into containers; see docker-compose.yml). Keep the top-level
# folder itself (.gitkeep) but never commit its contents.
/volumes/*
!/volumes/.gitkeep

# Local preview/screenshot artifacts
/.preview/

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# Node / frontend
node_modules/
frontend/dist/
*.tsbuildinfo
npm-debug.log*

# Editor / OS
.DS_Store
.idea/
.vscode/

# Claude Code personal overrides (never commit)
CLAUDE.local.md
.claude/settings.local.json
