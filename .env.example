# Copy to .env when you want to override defaults. Never commit .env or volumes/.

# ============================================================================
# Project
# ============================================================================
COMPOSE_PROJECT_NAME=privacy-deidentification
TZ=Europe/Vienna

# ============================================================================
# Ports
# ============================================================================
WEB_PORT=8080

# ============================================================================
# Runtime
# ============================================================================
MAX_UPLOAD_BYTES=10485760
ALLOWED_EXTENSIONS=pdf,docx,png,jpg,jpeg
LOG_LEVEL=INFO

# Default runtime: OCR jobs are queued in SQLite and processed by the isolated ocr-worker service.
# Use OCR_EXECUTION_MODE=sync only as a development/test fallback; then POST .../ocr returns the
# text artifact directly instead of 202 job status.
OCR_EXECUTION_MODE=worker

# ============================================================================
# Storage
# ============================================================================
# Single host data root. Compose maps these subdirectories onto stable internal container paths:
#   ${DATA_ROOT}/uploads               originals (byte-identical)
#   ${DATA_ROOT}/document-store        metadata, immutable artifacts, review/feedback sidecars
#   ${DATA_ROOT}/job-state             SQLite job metadata DB (jobs.sqlite3, ids/status only)
#   ${DATA_ROOT}/pii-feedback-archive  cross-document dev feedback log
#   ${DATA_ROOT}/ocr-models            local PaddleOCR models (mounted read-only)
# Everything under it is git-ignored; back it up as one unit. The container-internal paths are
# advanced overrides only (see the bottom of this file) because changing them independently can
# split API/worker storage.
DATA_ROOT=./volumes

# ============================================================================
# OCR worker resources
# ============================================================================
API_MEMORY_LIMIT=1g
OCR_WORKER_MEMORY_LIMIT=2g
OCR_WORKER_POLL_INTERVAL_SECONDS=2.0
OCR_WORKER_CONCURRENCY=1
# An interrupted attempt (worker crash/restart) is requeued while attempts remain, so 2 means
# exactly one automatic retry before the job fails explicitly as "interrupted".
OCR_WORKER_MAX_ATTEMPTS=2

# ============================================================================
# OCR models
# ============================================================================
# Install once with: make ocr-models
OCR_DETECTION_MODEL_NAME=PP-OCRv5_mobile_det
OCR_RECOGNITION_MODEL_NAME=latin_PP-OCRv5_mobile_rec

# ============================================================================
# PII
# ============================================================================
PII_LANGUAGE=de
PII_SPACY_MODEL=de_core_news_sm
PII_SCORE_THRESHOLD=0.5
PII_PROFILE=review-heavy
PII_CANDIDATE_VALIDATION_ENABLED=true

# Dev-only: enables one-run PII profile overrides and local per-entity feedback capture.
ENABLE_DEV_ENGINE_SETTINGS=false

# ============================================================================
# Advanced overrides (rarely needed)
# ============================================================================
# Container-internal storage paths. Defaults are stable and shared by the API and OCR worker; set
# them only if you know why. The SQLite job DB defaults to ${DATA_JOB_STATE_DIR}/jobs.sqlite3 and
# must stay on a path mounted into both services.
# UPLOAD_STORAGE_DIR=/data/uploads
# DOCUMENT_DATA_DIR=/data/document-store
# DATA_JOB_STATE_DIR=/data/job-state
# PII_FEEDBACK_ARCHIVE_DIR=/data/pii-feedback-archive
# OCR_MODEL_DIR=/models/ocr
# JOB_STORE_DB_PATH=/data/job-state/jobs.sqlite3

# One-run PII allowlist override. If set, this replaces PII_PROFILE entirely.
# PII_ENTITY_TYPES=EMAIL_ADDRESS,PHONE_NUMBER,IBAN_CODE,UID_AT,FN_AT,BIC,PERSON,ORGANIZATION,LOCATION
