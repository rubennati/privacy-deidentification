# Copy to .env. Never commit .env or volumes/.

# ============================================================================
# 1. Basic app
# ============================================================================
WEB_PORT=8080
MAX_UPLOAD_BYTES=10485760
ALLOWED_EXTENSIONS=pdf,docx,png,jpg,jpeg
LOG_LEVEL=INFO

# ============================================================================
# 2. Storage
# ============================================================================
# Container paths. Host data lives under ./volumes/.
UPLOAD_STORAGE_DIR=/data/uploads
DOCUMENT_DATA_DIR=/data/document-data
# Keep uploads and document-data separate. Never commit volumes/.

# ============================================================================
# 3. Runtime selection
# ============================================================================
# Usually use make targets:
# make up        = slim
# make up-pii    = PII
# make up-ocr    = OCR
# make up-full   = OCR + PII

INSTALL_OCR=true
INSTALL_PII=true
# Only relevant when running docker compose directly; make targets override these.

# ============================================================================
# 4. OCR
# ============================================================================
# OCR models must be installed once with: make ocr-models
OCR_MODEL_DIR=/models/ocr
OCR_DETECTION_MODEL_NAME=PP-OCRv5_mobile_det
OCR_RECOGNITION_MODEL_NAME=latin_PP-OCRv5_mobile_rec
# Missing models return 503. OCR can be slow on CPU.

# ============================================================================
# 5. PII
# ============================================================================
PII_LANGUAGE=de
PII_SPACY_MODEL=de_core_news_sm
PII_SCORE_THRESHOLD=0.5

# review-heavy = widest local review mode: structured + AT/DE/domain IDs + PERSON/ORG/LOCATION + DATE_TIME.
# Use this when a human reviews results.
PII_PROFILE=review-heavy

# Filters obvious false positives after detection.
PII_CANDIDATE_VALIDATION_ENABLED=true

# Dev-only: allow the document detail UI to override selected PII run settings for one local
# request. Keep disabled outside local development/review.
ENABLE_DEV_ENGINE_SETTINGS=false

# ============================================================================
# 6. PII profiles
# ============================================================================
# PII_PROFILE options:
# structured-only  = minimal: email, phone, IBAN, credit card, IP, URL
# insurance-at-de  = structured + AT/DE/domain IDs; no broad NER
# broad-review     = insurance-at-de + PERSON/ORGANIZATION/LOCATION
# review-heavy     = broad-review + DATE_TIME; most coverage, most review noise
#
# For interactive human review, use review-heavy.
# For fewer false positives, use insurance-at-de.
# For minimal smoke tests, use structured-only.

# ============================================================================
# 7. Advanced override
# ============================================================================
# Optional custom allowlist. Leave commented out unless debugging.
# If set, it overrides PII_PROFILE.
# PII_ENTITY_TYPES=EMAIL_ADDRESS,PHONE_NUMBER,IBAN_CODE,UID_AT,FN_AT,BIC,PERSON,ORGANIZATION,LOCATION

# Optional container memory limit; make ocr/pii/full targets raise this automatically.
BACKEND_MEMORY_LIMIT=512M

# ============================================================================
# 8. Troubleshooting short notes
# ============================================================================
# If PII detects too little:
# - use PII_PROFILE=review-heavy
# - make sure PII_ENTITY_TYPES is commented out
# - recreate containers
# - rerun PII for the document
#
# If PII is too noisy:
# - use PII_PROFILE=insurance-at-de
# - keep PII_CANDIDATE_VALIDATION_ENABLED=true
#
# If OCR returns 503:
# - run make ocr-models
# - use make up-ocr or make up-full
