# Copy to .env and adjust as needed. Never commit the real .env.
# These values are safe defaults for local development.

# Host port for the web app (nginx frontend). Open http://localhost:${WEB_PORT}
WEB_PORT=8080

# --- Backend configuration (read by app/config.py) ---

# Maximum accepted upload size in bytes (default 10 MiB).
MAX_UPLOAD_BYTES=10485760

# Comma-separated allowed file extensions (lowercase, no dot).
ALLOWED_EXTENSIONS=pdf,docx,png,jpg,jpeg

# Separate container directories for original uploads and application-managed document data.
# Compose mounts them from ./volumes/uploads and ./volumes/document-data respectively.
UPLOAD_STORAGE_DIR=/data/uploads
DOCUMENT_DATA_DIR=/data/document-data

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Runtime profiles are normally selected via make targets (up / up-pii / up-ocr / up-full),
# which set these build args for you. Set them here only if you run docker compose directly.
# Build the backend with the optional PaddleOCR/PaddlePaddle runtime. Keep false when only
# upload, audit, DOCX extraction, or PDF text-layer extraction is needed.
INSTALL_OCR=false

# Container-internal model root, mounted read-only from ./volumes/ocr-models (see
# docker-compose.yml). Ignored when INSTALL_OCR=false. Populate it with `make ocr-models`; if the
# models are missing the OCR station returns 503 and never downloads at runtime.
OCR_MODEL_DIR=/models/ocr
# Names of the provisioned models; must match what fetch-ocr-models.sh downloaded. The Latin
# recognizer covers German/Latin-script documents (umlauts, ß). Empty = PaddleOCR's own default.
OCR_DETECTION_MODEL_NAME=PP-OCRv5_mobile_det
OCR_RECOGNITION_MODEL_NAME=latin_PP-OCRv5_mobile_rec

# Optional container memory limit; the ocr/pii/full make targets raise it for the heavy runtimes.
BACKEND_MEMORY_LIMIT=512M

# Build Presidio, spaCy, and the pinned German spaCy model into the backend image.
INSTALL_PII=false

# PII Workstation v1 uses one configured language/model and performs detection only.
PII_LANGUAGE=de
PII_SPACY_MODEL=de_core_news_sm
PII_SCORE_THRESHOLD=0.5
# Named profiles: structured-only (default), insurance-at-de, broad-review, review-heavy.
# PERSON/ORGANIZATION/LOCATION and DATE_TIME remain opt-in through the latter two profiles.
PII_PROFILE=structured-only
# Optional backwards-compatible allowlist override. Leave unset to derive types from PII_PROFILE.
# PII_ENTITY_TYPES=EMAIL_ADDRESS,PHONE_NUMBER,IBAN_CODE,CREDIT_CARD,IP_ADDRESS,URL,PERSON,ORGANIZATION,LOCATION,DATE_TIME
